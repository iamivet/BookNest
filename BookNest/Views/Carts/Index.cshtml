@model IEnumerable<BookNest.Data.Cart>

@{
    ViewData["Title"] = "Index";
}

@section Scripts {
    <script src="~/js/cart.js"></script>
}

<link rel="stylesheet" href="~/css/cart.css" />
@if (Model.Any())
{
    <div class="cart-box">
        <h1>Количка</h1>

        <table>
            <thead>
                <tr>
                    <th>Артикул</th>
                    <th>Име</th>
                    <th>Цена</th>
                    <th>Кол-во</th>
                    <th>Сума</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="cart-item">
                        <td><img src="@item.Book.CoverImage" alt="@item.Book.Title"></td>
                        <td>@item.Book.Title</td>
                        <td class="book-price" data-price="@item.Book.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">@item.Book.Price</td>
                        <td>
                            <span class="view-mode quantity-text">@item.Quantity</span>
                            <input type="number" class="quantity-input" value="@item.Quantity" min="1" style="width:50px;display:none;">
                        </td>
                        <td class="item-total">@(item.Quantity* item.Book.Price) €</td>
                        <td class="actions">
                            <button type="button" class="view-mode change-qty-btn" onclick="showElements(this)">Промени бройката</button>

                            <form asp-controller="Carts" asp-action="Edit" method="post" class="edit-mode" style="display:none;">
                                @Html.AntiForgeryToken() <input type="hidden" name="Id" value="@item.Id" />
                                <input type="hidden" name="BookId" value="@item.BookId" />
                                <input type="hidden" name="CustomerId" value="@item.CustomerId" />

                                <input type="hidden" name="Quantity" class="hidden-quantity" value="@item.Quantity" />

                                <button type="submit" class="edit-btn">Редактирай</button>
                            </form>
                            <button class="remove-btn otkaz" onclick="hideElements(this)" style="display:none;">Отказ</button>
                            <button class="remove-btn" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.Id">Премахни</button>
                            

                            <partial name="_DeleteModalPartial" model="item" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="summary">
            <h2>Обобщение</h2>
            @{
                decimal totalSum = 0;
                foreach (var item in Model)
                {
                    totalSum += (item.Quantity * item.Book.Price);
                }
                <p><span>Сума:</span><span id="grand-total">@totalSum €</span></p>
                <button class="btn-2d-checkout" data-bs-toggle="modal" data-bs-target="#checkoutModal">Поръчай</button>
            }


            <partial name="_CheckoutModalPartial" model="Model" />
        </div>

        <div style="clear: both; margin-top: 30px;">
            <a class="btn-continue" style="padding:10px 20px;" asp-controller="Books" asp-action="Index">Продължи с пазаруването</a>
        </div>
    </div>
}
else
{

    <div class="empty-cart-wrapper">
        <div class="empty-cart-card">
            <div class="icon-container">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#d59b6c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
            </div>

            <h2 class="empty-cart-title">Количката ви е празна!</h2>
            <p class="empty-cart-subtitle">Изглежда все още не сте добавили нищо. Разгледайте нашите предложения и намерете следващата си любима книга.</p>

            <a class="btn-continue" asp-controller="Books" asp-action="Index">Пазарувай сега</a>
        </div>
    </div>
}


