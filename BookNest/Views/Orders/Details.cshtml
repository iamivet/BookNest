@model IEnumerable<BookNest.Data.Order>

@{
    ViewData["Title"] = "Детайли на поръчката";
    var firstOrder = Model.First();
    var customer = firstOrder.Customer;
}

@* <link rel="stylesheet" href="~/css/order.css" /> *@

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title mb-0"><i class="fas fa-info-circle"></i> Детайли на поръчката</h1>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
            <i class="fas fa-arrow-left"></i> Обратно към списъка
        </a>
    </div>

    <div class="row">
        <div class="col-md-5">
            <div class="order-group-card p-4 shadow-sm h-100">
                <h4 class="border-bottom pb-2 mb-3 text-brown"><i class="fas fa-user"></i> Данни за доставка</h4>

                <div class="customer-detail-item mb-3">
                    <label class="text-muted d-block small uppercase">Клиент</label>
                    <span class="fw-bold">@customer.UserName</span>
                </div>

                <div class="customer-detail-item mb-3">
                    <label class="text-muted d-block small uppercase">Телефон за връзка</label>
                    <span class="fw-bold">@customer.PhoneNumber</span>
                </div>

                <div class="customer-detail-item mb-3">
                    <label class="text-muted d-block small uppercase">Адрес за доставка</label>
                    <span class="fw-bold">@customer.Address</span>
                </div>

                <div class="customer-detail-item mb-4">
                    <label class="text-muted d-block small uppercase">Дата на поръчка</label>
                    <span class="fw-bold">@firstOrder.CreatedOn.ToString("dd.MM.yyyy HH:mm")</span>
                </div>

                <div class="alert alert-info border-0 rounded-3" style="background-color: #f0f7ff;">
                    <i class="fas fa-info-circle me-2"></i>
                    @if (User.Identity.IsAuthenticated && User.IsInRole("Customer"))
                    {
                        <small>
                            За да промените вашия адрес или телефонен номер, моля влезте в
                            <strong>настройките на профила</strong> си и ги актуализирайте от там.
                        </small>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="order-group-card shadow-sm h-100">
                <div class="p-3 bg-light border-bottom">
                    <h4 class="mb-0 text-brown"><i class="fas fa-books"></i> Поръчани книги</h4>
                </div>

                <div class="order-items p-4">
                    @foreach (var item in Model)
                    {
                        <div class="order-footer p-4 bg-light border-top d-flex justify-content-between align-items-center">
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Сигурни ли сте, че искате да изтриете тази поръчка?');">
                                <button type="submit" class="btn btn-delete-order">
                                    <i class="fas fa-trash-alt"></i> Премахни книга
                                </button>
                            </form>

                            <form asp-action="Edit" method="post" class="d-flex align-items-center">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="Id" value="@item.Id" />
                                <input type="hidden" name="BookId" value="@item.BookId" />
                                <input type="hidden" name="CustomerId" value="@item.CustomerId" />

                                <input type="hidden" name="CreatedOn" value="@item.CreatedOn.ToString("s")" />

                                <div class="input-group input-group-sm me-2" style="width: 130px;">
                                    <span class="input-group-text bg-white text-muted">Брой:</span>
                                    <input type="number" name="Quantity" value="@item.Quantity" min="1" class="form-control quantity-input" />
                                </div>
                                <button type="submit" class="btn btn-update-qty btn-sm">
                                    <i class="fas fa-sync-alt"></i> Обнови
                                </button>
                            </form>
                        </div>
                        <div class="order-item d-flex align-items-center mb-4 pb-3 border-bottom-dashed">
                            <div class="book-preview position-relative me-4">
                                <img src="@item.Book.CoverImage" alt="Книга" class="book-thumb-large" />
                                <span class="item-quantity-badge">@item.Quantity</span>
                            </div>
                            <div class="book-details flex-grow-1">
                                <h5 class="book-title mb-1">@item.Book.Title</h5>
                                <p class="text-muted mb-0">Единична цена: @item.Book.Price.ToString("F2") лв.</p>
                                <p class="fw-bold text-brown">Междинна сума: @((item.Quantity * item.Book.Price).ToString("F2")) лв.</p>
                            </div>
                        </div>
                     
                    }
                </div>
                
                <div class="order-footer p-4 bg-light border-top text-end">
                    <h3 class="mb-0">
                        Обща сума: <span class="text-brown fw-bold">@Model.Sum(x => x.Quantity * x.Book.Price).ToString("F2") лв.</span>
                    </h3>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-brown {
        color: #5A3E2B;
    }

    .uppercase {
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 1px;
    }

    .book-thumb-large {
        width: 80px;
        height: 110px;
        object-fit: cover;
        border-radius: 8px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .item-quantity-badge {
        position: absolute;
        top: -10px;
        right: -10px;
        background: #D27D56;
        color: white;
        padding: 5px 10px;
        border-radius: 50%;
        font-weight: bold;
        font-size: 0.9rem;
        border: 2px solid white;
    }

    .border-bottom-dashed {
        border-bottom: 1px dashed #dee2e6;
    }

    .order-item:last-child {
        border-bottom: none;
    }

    .btn-delete-order {
        background-color: transparent;
        color: #dc3545; /* Червен цвят за внимание */
        border: 1px solid #dc3545;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

        .btn-delete-order:hover {
            background-color: #dc3545;
            color: white;
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.2);
            transform: translateY(-1px);
        }

        .btn-delete-order i {
            margin-right: 8px;
        }

    /* Корекция за футъра, за да подреди елементите в двата края */
    .order-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-update-qty {
        background-color: #5A3E2B;
        color: white;
        border: none;
        border-radius: 50px;
        padding: 5px 15px;
        font-size: 0.85rem;
        transition: all 0.3s ease;
    }

        .btn-update-qty:hover {
            background-color: #3e2b1e;
            box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        }

    /* Изчистване на input-а */
    .quantity-input {
        border: 1px solid #ced4da;
        text-align: center;
        font-weight: bold;
    }

        .quantity-input:focus {
            border-color: #D27D56;
            box-shadow: 0 0 0 0.2rem rgba(210, 125, 86, 0.25);
        }

    /* Малка корекция за бутона за изтриване, когато е икона */
    .btn-delete-order.btn-sm {
        padding: 5px 12px;
        font-size: 0.85rem;
    }

    .order-item-wrapper:last-child {
        border-bottom: none;
    }
</style>