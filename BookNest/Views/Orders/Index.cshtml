@model IEnumerable<BookNest.Data.Order>

@{
    ViewData["Title"] = "Поръчки";

    var groupedOrders = Model.GroupBy(o => new
    {
        o.CustomerId,
        UserName = o.Customer,
        MinuteDate = o.CreatedOn.ToString("yyyy-MM-dd HH:mm")
    });
}

<link rel="stylesheet" href="~/css/order.css" />

<div class="container mt-5">
    <div class="orders-header">
        <h1 class="page-title">
            <i class="fas fa-box-open"></i>
            @(User.IsInRole("Admin") ? "Всички поръчки" : "Моите поръчки")
        </h1>
        @if (User.IsInRole("Customer"))
        {
            <p class="text-center text-muted">Тук можете да следите историята на вашите покупки.</p>
        }
    </div>
</div>

<div class="orders-list">
    @foreach (var group in groupedOrders)
    {
        <div class="order-group-card mb-4">
            <div class="order-header-info">
                <div class="order-meta">
                    <span class="order-id"># ОБЩА ПОРЪЧКА</span>
                    <span class="order-date">
                        <i class="far fa-calendar-alt"></i> @group.First().CreatedOn.ToString("dd.MM.yyyy HH:mm")
                    </span>
                </div>
                @if (User.IsInRole("Admin"))
                {
                    <div class="customer-info">
                        <i class="fas fa-user-circle"></i> Клиент: <strong>@group.Key.UserName</strong>
                    </div>
                }
            </div>

            <div class="order-items p-3">
                @foreach (var item in group)
                {
                    <div class="order-item d-flex align-items-center mb-3">
                        <div class="book-preview position-relative me-3">
                            <img src="@item.Book.CoverImage" alt="Книга" class="book-thumb" style="width: 60px; height: 85px; object-fit: cover; border-radius: 5px;" />
                            <span class="item-quantity">@item.Quantity</span>
                        </div>
                        <div class="book-details">
                            <h5 class="book-title mb-1">@item.Book.Title</h5>
                            <p class="book-price mb-0 text-muted">Цена: @item.Book.Price.ToString("F2") €</p>
                        </div>
                    </div>
                }
            </div>

            <div class="order-footer d-flex justify-content-between align-items-center p-3" style="background: #f9f9f9;">
                <div class="total-section">
                    Обща сума: <strong class="text-dark" style="font-size: 1.2rem;">
                        @group.Sum(x => x.Quantity * x.Book.Price).ToString("F2") €
                    </strong>
                </div>
                <div class="order-actions">
                    <a asp-action="Details" asp-route-id="@group.First().Id" class="btn btn-sm btn-outline-secondary">Детайли</a>
                </div>
            </div>
        </div>
    }
</div>