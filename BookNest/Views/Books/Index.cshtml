@model IEnumerable<BookNest.Data.Book>

@{
    ViewData["Title"] = "Index";
}
<link rel="stylesheet" href="~/css/bookIndex.css" />
<p>
    <a asp-action="Create" class="view-more">Create New</a>
</p>

<div class="conteiner">
    @foreach (var item in Model)
    {

        <div class="box">
            <p> @item.Title</p>
            <div class="book">

                <img src="@item.CoverImage" alt="@item.Title" />
                <span><span class="price">Цена:</span>  @item.Price €</span>
                <span><span class="author">Автор:</span>  @item.Author.Name</span>
            </div>
            <a asp-action="Details" asp-route-id="@item.Id" class="view-more">Виж повече</a>
            <a asp-action="Edit" asp-route-id="@item.Id" class="view-more">Edit</a>
            <a asp-action="Delete" asp-route-id="@item.Id" class="view-more">Delete</a>
        </div>
    }
</div>
