<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookNest</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookNest.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>

<body>

    <header>

        <nav class="navbar navbar-expand-sm navbar-light border-bottom">

            <div class="container-fluid">

               

                <a class="navbar-brand"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">

                    <img src="~/images/logo.png" alt="Logo" />

                </a>

               
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                       <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle text-dark"
                               href="#"
                               id="booksDropdown"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">


                                <i class="fas fa-book-open"></i>
                                <span class="nav-text">
                                    Литература
                                    <span></span>
                                </span>

                            </a>

                            <ul class="dropdown-menu">

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Books"
                                       asp-action="Index"
                                       asp-route-type="BG">

                                        🇧🇬 Българска литература
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Books"
                                       asp-action="Index"
                                       asp-route-type="Foreign">

                                        🌍 Чуждоезикова литература
                                    </a>
                                </li>

                                <li>
                                    <hr class="dropdown-divider">
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Books"
                                       asp-action="Index">

                                        📚 Всички книги
                                    </a>
                                </li>

                            </ul>

                        </li>

               
                        <li class="nav-item">

                            <a class="nav-link text-dark"
                               asp-controller="Authors"
                               asp-action="Index">

                                <i class="fas fa-feather"></i>

                                <span class="nav-text">
                                    Автори
                                </span>

                            </a>

                        </li>

               

                        <li class="nav-item">

                            <a class="nav-link text-dark"
                               asp-controller="Home"
                               asp-action="Contacts">

                                <i class="fas fa-envelope"></i>

                                <span class="nav-text">
                                    Контакти
                                </span>

                            </a>

                        </li>

                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            

                            <li class="nav-item">

                                <a class="nav-link text-dark"
                                   asp-controller="Categories"
                                   asp-action="Index">

                                    <i class="fas fa-layer-group"></i>

                                    <span class="nav-text">
                                        Категории
                                    </span>

                                </a>

                            </li>

                            
                            <li class="nav-item">

                                <a class="nav-link text-dark"
                                   asp-controller="Publishers"
                                   asp-action="Index">

                                    <i class="fas fa-building"></i>

                                    <span class="nav-text">
                                        Издателства
                                    </span>

                                </a>

                            </li>

                            <li class="nav-item">

                                <a class="nav-link text-dark"
                                   asp-controller="Orders"
                                   asp-action="Index">

                                    <i class="fas fa-box"></i>

                                    <span class="nav-text">
                                        Поръчки
                                    </span>

                                </a>

                            </li>
                        }

                        else if (User.Identity.IsAuthenticated && User.IsInRole("Customer"))
                        {
                            
                            <li class="nav-item">

                                <a class="nav-link text-dark"
                                   asp-controller="Orders"
                                   asp-action="CustomerOrders">

                                    <i class="fas fa-receipt"></i>

                                    <span class="nav-text">
                                        Моите поръчки
                                    </span>

                                </a>

                            </li>

                            <li class="nav-item">

                                <a class="nav-link text-dark"
                                   asp-controller="Carts"
                                   asp-action="Index">

                                    <i class="fas fa-cart-shopping"></i>

                                    <span class="nav-text">
                                        Количка
                                    </span>

                                </a>

                            </li>
                        }

                    </ul>

                    <partial name="_LoginPartial" />

                </div>

            </div>

        </nav>

    </header>
    <div class="container content-wrapper">
       

        <main role="main" class="pb-3">

            @RenderBody()

        </main>

    </div>

    <footer >

        <div class="container">

            &copy; 2026 - BookNest

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>