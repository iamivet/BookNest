@page
@model IndexModel
@{
    ViewData["Title"] = "Профил";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<link rel="stylesheet" href="~/css/manageIndex.css" />

<div class="manage-container">
    <h3 class="manage-title">@ViewData["Title"]</h3>
    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="row profile-card">
        <div class="col-md-12">
            <form id="profile-form" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="form-group mb-3">
                    <label asp-for="Username" class="custom-label">Потребителско име</label>
                    <input asp-for="Username" class="form-control custom-input" placeholder="Потребителско име" disabled />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Input.PhoneNumber" class="custom-label">Телефонен номер</label>
                    <input asp-for="Input.PhoneNumber" class="form-control custom-input" placeholder="Въведете телефон..." />
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Input.Address" class="custom-label">Адрес за доставка</label>
                    <input asp-for="Input.Address" class="form-control custom-input" placeholder="гр. София, ул. ..." />
                    <span asp-validation-for="Input.Address" class="text-danger"></span>
                </div>

                <button id="update-profile-button" type="submit" class="btn-save">Запази промените</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}